# Copy to .env.local and fill in your values.

# === LLM API Keys (server-side only) ===
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Google OAuth (used by Supabase Auth provider) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Polar.sh Billing (optional — app falls back to "free for everyone" if absent) ===
# Get an Organization Access Token from https://polar.sh → Settings → Developers
POLAR_ACCESS_TOKEN=
# Create a recurring product for the Pro plan in the Polar dashboard and paste
# its UUID (looks like 0e8d…-…-…) here. Each product can have one or more prices,
# but the checkout endpoint only needs the product id.
POLAR_PRO_PRODUCT_ID=
# Create a webhook endpoint pointing at /api/polar/webhook in Polar (Settings →
# Webhooks) listening to subscription.* events. Copy the signing secret here.
POLAR_WEBHOOK_SECRET=
# Optional. Defaults to "production" in prod, "sandbox" in dev. Set to
# "production" in dev only if you want to test against live data from local.
# POLAR_SERVER=sandbox
