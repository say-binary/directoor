# Copy to .env.local and fill in your values.

# === LLM API Keys (server-side only) ===
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Google OAuth (used by Supabase Auth provider) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Stripe Billing (optional — app falls back to "free for everyone" if absent) ===
# Get the secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Create a recurring price for the Pro plan in Stripe and paste its id here
STRIPE_PRO_PRICE_ID=
# Create a webhook endpoint pointing at /api/stripe/webhook in Stripe and copy
# the signing secret here. Required so the webhook can verify Stripe payloads.
STRIPE_WEBHOOK_SECRET=
