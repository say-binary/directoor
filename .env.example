# ─── Directoor Environment Variables ──────────────────────────────
# Copy this file to apps/web/.env.local and fill in the values.
# See README.md for where to get each key.

# ─── LLM API Keys (server-side only) ───────────────────────────────
# Get from https://console.anthropic.com — primary intent router (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: fallback model (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=AIza...

# ─── Supabase ──────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# CRITICAL: SERVICE ROLE bypasses RLS. Treat like a password.
# Never expose to client code or commit to git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Google OAuth ──────────────────────────────────────────────────
# From: https://console.cloud.google.com → APIs & Services → Credentials
# Used by Supabase Auth — also paste these into Supabase Dashboard
# under Authentication → Providers → Google.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
